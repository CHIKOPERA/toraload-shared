{
    "name": "@toraload/shared",
    "version": "1.0.0",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./payment-methods": {
            "types": "./dist/payment-methods.d.ts",
            "default": "./dist/payment-methods.js"
        },
        "./enums": {
            "types": "./dist/enums.d.ts",
            "default": "./dist/enums.js"
        },
        "./schemas": {
            "types": "./dist/schemas.d.ts",
            "default": "./dist/schemas.js"
        },
        "./types": {
            "types": "./dist/types.d.ts",
            "default": "./dist/types.js"
        },
        "./constants": {
            "types": "./dist/constants.d.ts",
            "default": "./dist/constants.js"
        },
        "./websocket": {
            "types": "./dist/websocket.d.ts",
            "default": "./dist/websocket.js"
        }
    },
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "prepare": "pnpm build"
    },
    "dependencies": {
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/node": "^20.11.5",
        "typescript": "^5.3.3"
    }
}
